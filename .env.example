# siemens_rpp environment contract (copy to .env; .env is gitignored).
# Names match the existing fleet .env so this app drops into the same setup.

APP_NAME=siemens_rpp
# dev | staging | prod — controls the run-log file path:
#   dev          -> ./<app>-log.<logger>.<run_id>.json   (RELATIVE; native host only)
#   staging|prod -> /opt/run-logs/<app>/...               (the mounted, svc-writable dir)
# The baked container runs as svc with a root-owned /workspace, so containerized
# runs MUST use staging or prod. Use dev only for native `cargo run` on the host.
RUN_ENV=staging
LOGGER=dev             # dev console verbosity + log filename tag

# --- Postgres (server requires SSL; TD-020) ---
PGHOST=pg_db
PGPORT=5432
PGUSER=postgres
PGPASSWORD=            # set in real .env only; never commit
PGDATABASE=dev
PG_SSLMODE=require     # disable | require | verify-ca | verify-full
                       # require = encrypted, NO cert verification (Node rejectUnauthorized:false)
                       # (default when unset is `require`; Node defaults to `disable`)
PG_SSL_PATH=./pg_ssl.crt   # CA cert (PEM); used ONLY for verify-ca/verify-full
                       # (ignored under disable/require)
# PG_POOL_MAX=16

# --- Redis (no auth/TLS, matches Node) ---
REDIS_HOST=redis_dev-0-4
REDIS_PORT=6379

# --- File store (renamed from Node DATA_STORE_DEV; same value) ---
ACQU_FILES_ROOT=/opt/resources/acqu_files

# --- Container runtime ---
RUN_USER=svc

# Run-logs bind mount, given as a host:container pair (docker-compose volume spec).
# The host dir must exist and be writable by RUN_USER (svc). Both sides are usually
# the same /opt/run-logs/<app> path:
RUN_LOGS_DIR=/opt/run-logs/siemens_rpp:/opt/run-logs/siemens_rpp

# Image build args: the docker group + the UIDs baked into the runtime image so
# host-mounted run-logs get sane ownership (docker/Dockerfile groupadd/useradd,
# docker-compose build.args). Match these to the fleet host's real ids —
# e.g. `getent group docker | cut -d: -f3` for DOCKER_GID, `id -u <user>` for UIDs.
# The values below are the current fleet host's; change per host.
DOCKER_GID=990
UID_0=104          # svc       (RUN_USER; owns run-log files)
UID_1=1001         # jonathan-pope
UID_2=1006         # matt-teixeira

# Set automatically by docker-compose (environment: APP_CONTAINER=1); do NOT set
# this in a host .env. It makes the app reject RUN_ENV=dev inside the container.
# APP_CONTAINER=1
